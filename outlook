Sub SaveAndPrintPDFs_Adobe()

    Dim objItem As Object
    Dim objMail As Outlook.MailItem
    Dim objAttachments As Outlook.Attachments
    Dim objAttachment As Outlook.Attachment
    Dim saveFolder As String
    Dim filePath As String
    Dim fileName As String
    Dim i As Integer
    Dim adobePath As String
    
    ' Ścieżka do Adobe Reader (sprawdź czy taka sama u Ciebie)
    adobePath = "C:\Program Files\Adobe\Acrobat Reader DC\Reader\AcroRd32.exe"
    
    ' Folder zapisu
    saveFolder = "C:\PDF_OUTLOOK\"
    
    ' Tworzy folder jeśli nie istnieje
    If Dir(saveFolder, vbDirectory) = "" Then
        MkDir saveFolder
    End If
    
    ' Przechodzi po zaznaczonych mailach
    For Each objItem In Application.ActiveExplorer.Selection
        
        If TypeOf objItem Is Outlook.MailItem Then
            Set objMail = objItem
            Set objAttachments = objMail.Attachments
            
            For Each objAttachment In objAttachments
                
                ' Tylko PDF
                If LCase(Right(objAttachment.FileName, 4)) = ".pdf" Then
                    
                    fileName = objAttachment.FileName
                    filePath = saveFolder & fileName
                    
                    ' Jeśli plik istnieje → dodaj numer
                    i = 1
                    Do While Dir(filePath) <> ""
                        filePath = saveFolder & i & "_" & fileName
                        i = i + 1
                    Loop
                    
                    ' Zapis pliku
                    objAttachment.SaveAsFile filePath
                    
                    ' Druk przez Adobe (cichy)
                    Shell """" & adobePath & """ /t """ & filePath & """", vbHide
                    
                End If
                
            Next
            
        End If
        
    Next
    
    MsgBox "Gotowe! PDFy wydrukowane 🚀"

End Sub
