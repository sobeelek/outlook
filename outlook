Sub SaveOpenAndPrintPDFs()

    Dim objItem As Object
    Dim objMail As Outlook.MailItem
    Dim objAttachment As Outlook.Attachment
    Dim saveFolder As String
    Dim filePath As String
    Dim fileName As String
    Dim i As Integer
    Dim adobePath As String
    
    ' 🔎 szuka Acrobata automatycznie
    If Dir("C:\Program Files\Adobe\Acrobat DC\Acrobat\Acrobat.exe") <> "" Then
        adobePath = "C:\Program Files\Adobe\Acrobat DC\Acrobat\Acrobat.exe"
    ElseIf Dir("C:\Program Files (x86)\Adobe\Acrobat DC\Acrobat\Acrobat.exe") <> "" Then
        adobePath = "C:\Program Files (x86)\Adobe\Acrobat DC\Acrobat\Acrobat.exe"
    Else
        MsgBox "Nie znaleziono Acrobata!"
        Exit Sub
    End If
    
    ' 📁 PULPIT
    saveFolder = Environ("USERPROFILE") & "\Desktop\PDF_OUTLOOK\"
    
    ' tworzy folder jeśli nie istnieje
    If Dir(saveFolder, vbDirectory) = "" Then
        MkDir saveFolder
    End If
    
    For Each objItem In Application.ActiveExplorer.Selection
        
        If TypeOf objItem Is Outlook.MailItem Then
            
            For Each objAttachment In objItem.Attachments
                
                If LCase(Right(objAttachment.FileName, 4)) = ".pdf" Then
                    
                    fileName = objAttachment.FileName
                    filePath = saveFolder & fileName
                    
                    i = 1
                    Do While Dir(filePath) <> ""
                        filePath = saveFolder & i & "_" & fileName
                        i = i + 1
                    Loop
                    
                    objAttachment.SaveAsFile filePath
                    
                    ' 🔥 otwiera + drukuje
                    Shell """" & adobePath & """ /t """ & filePath & """", vbNormalFocus
                    
                End If
                
            Next
            
        End If
        
    Next
    
    MsgBox "Gotowe"

End Sub
