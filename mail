' 🔥 GŁÓWNA LOGIKA
Private Sub Handle(mail As Object)
    If TypeOf mail Is Outlook.MailItem Then
        ProcessMail mail
    End If
End Sub

Private Sub ProcessMail(mail As Outlook.MailItem)

    ' tylko nieprzeczytane
    If mail.UnRead = True Then
        
        ' bez duplikatów
        If InStr(mail.Categories, "FORWARDED") = 0 Then
            
            Dim fwd As Outlook.MailItem
            Set fwd = mail.Forward
            
            ' 🔥 TU TWÓJ MAIL
            fwd.Recipients.Add "mail@twojadomena.pl"
            
            fwd.Send
            
            ' oznacz jako przetworzony
            mail.Categories = mail.Categories & ";FORWARDED"
            mail.Save
            
        End If
    End If

End Sub

' 🔥 PRZELOT PO STARYCH MAILACH
Private Sub ProcessFolder(folder As Outlook.MAPIFolder)
    Dim item As Object
    
    For Each item In folder.Items
        If TypeOf item Is Outlook.MailItem Then
            ProcessMail item
        End If
    Next
End Sub
